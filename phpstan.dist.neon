parameters:
    level: max
    phpVersion:
        min: 80100
        max: 80499
    paths:
        - src
        - tests
    ignoreErrors:
        - identifier: parameter.defaultValue
        - identifier: trait.unused
        - identifier: property.onlyWritten
        # WebSocket library casts mixed values from JSON arrays - these are safe
        -
            identifier: cast.string
            path: src/Lib/WebSocket/*
        -
            identifier: cast.int
            path: src/Lib/WebSocket/*
        -
            identifier: cast.double
            path: src/Lib/WebSocket/*

    reportUnmatchedIgnoredErrors: false
